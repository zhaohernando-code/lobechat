# Copy to deploy/.env, then replace all CHANGE_ME values.

# Runtime
LOBEHUB_IMAGE=lobehub-custom:latest
LOBEHUB_UPSTREAM_REPO=https://github.com/lobehub/lobehub.git
LOBEHUB_UPSTREAM_REF=main
USE_CN_MIRROR=false
LOBE_PORT=3210
LOBE_DATA_DIR=/Users/hernando_zhao/codex/projects/lobechat/data
APP_URL=https://hernando-zhao.cn
INTERNAL_APP_URL=http://lobe:3210
NEXT_PUBLIC_BASE_PATH=/chat

# Database
LOBE_DB_NAME=lobechat
POSTGRES_PORT=54329
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_scripts_lobehubctl_secrets
DATABASE_DRIVER=node

# Redis
REDIS_PORT=63790

# Better Auth / encrypted key vaults
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_scripts_lobehubctl_secrets
KEY_VAULTS_SECRET=CHANGE_ME_GENERATE_WITH_scripts_lobehubctl_secrets

# Phase 1 account gate: the root-domain OIDC bridge is the only account source.
AUTH_ALLOWED_EMAILS=
AUTH_DISABLE_EMAIL_PASSWORD=1
AUTH_EMAIL_VERIFICATION=0
AUTH_TRUSTED_ORIGINS=https://hernando-zhao.cn

# Root-domain SSO bridge. The real secret must match the server-side
# HZ_OIDC_CLIENT_SECRET and must not be committed to docs.
AUTH_SSO_PROVIDERS=generic-oidc
AUTH_GENERIC_OIDC_ID=lobehub
AUTH_GENERIC_OIDC_SECRET=CHANGE_ME_MATCH_SERVER_HZ_OIDC_CLIENT_SECRET
AUTH_GENERIC_OIDC_ISSUER=https://hernando-zhao.cn

# RustFS / S3
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ACCESS_KEY=lobehub_access_key
RUSTFS_SECRET_KEY=CHANGE_ME_GENERATE_WITH_scripts_lobehubctl_secrets
RUSTFS_LOBE_BUCKET=lobe
S3_ENDPOINT=http://rustfs:9000
S3_PUBLIC_DOMAIN=https://hernando-zhao.cn/chat-s3

# AI providers
OPENAI_API_KEY=
OPENAI_PROXY_URL=https://api.openai.com/v1
OPENAI_MODEL_LIST=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_LIST=

GOOGLE_API_KEY=
GOOGLE_MODEL_LIST=

# DeepSeek uses the OpenAI-compatible protocol.
DEEPSEEK_API_KEY=
DEEPSEEK_PROXY_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_LIST=deepseek-chat,deepseek-reasoner

# Optional network proxy for providers that are not directly reachable.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost,postgresql,redis,rustfs,searxng,lobe
